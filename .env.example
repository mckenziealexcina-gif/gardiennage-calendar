# ── Database ──────────────────────────────────────────────────────────────────
# Local SQLite (default)
DATABASE_URL="file:./dev.db"

# For Vercel production, use Turso (libSQL-compatible SQLite):
# DATABASE_URL="libsql://your-db-name.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"

# ── Resend ────────────────────────────────────────────────────────────────────
# Get your API key at https://resend.com — free tier: 3 000 emails/month
RESEND_API_KEY=
# Sender address (use onboarding@resend.dev for testing; verified domain for prod)
RESEND_FROM_EMAIL=

# ── Vercel Cron Security ──────────────────────────────────────────────────────
# Vercel sets this automatically in production.
# Locally: set any random string.
CRON_SECRET=
